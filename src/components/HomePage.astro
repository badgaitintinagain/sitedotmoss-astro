---
import Background from './Background.astro';
import ProfileButton from './ProfileButton.astro';
import SettingsModal from './SettingsModal.astro';

import WeatherTile from '@/components/WeatherTile';
import AdTile from './AdTile.astro';
import CalendarTile from '@/components/CalendarTile';
import ClockTile from '@/components/ClockTile';
import ShoeDemoTile from '@/components/ShoeDemoTile';
import NextWbcTile from '@/components/NextWbcTile';
import SpotifyAnalysisTile from '@/components/SpotifyAnalysisTile';
import BlogTile from './BlogTile.astro';
import ResourceTile from '@/components/ResourceTile';
import { Settings, Users, PenTool, StickyNote } from 'lucide-react';

const QUOTES = [
	{ text: 'The only way to do great work is to love what you do.', author: 'Steve Jobs', image: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=400&q=60' },
	{ text: 'Stay hungry, stay foolish.', author: 'Steve Jobs', image: 'https://images.unsplash.com/photo-1550745165-9bc0b252726f?auto=format&fit=crop&w=400&q=60' },
	{ text: 'The future belongs to those who believe in the beauty of their dreams.', author: 'Eleanor Roosevelt', image: 'https://images.unsplash.com/photo-1485872232694-217b2ad2303e?auto=format&fit=crop&w=400&q=60' },
] as const;

const randomQuote = QUOTES[Math.floor(Math.random() * QUOTES.length)];

const dashboardGroups = [
	{
		title: 'Life at a glance',
		tiles: [
			{ kind: 'react', component: ClockTile, props: { size: '2x2', label: 'Clock', accent: 'primary', opacity: 55 } },
			{ kind: 'react', component: CalendarTile, props: { size: '2x3', label: 'Calendar', accent: 'secondary', opacity: 65 } },
			{ kind: 'button', id: 'settings', size: '1x1', label: 'Settings', icon: Settings, accent: 'secondary', opacity: 60 },
			{ kind: 'quote', size: '3x2' },
			{ kind: 'astro', component: AdTile, props: { size: '3x2', title: 'New Collection 2025', description: 'Discover the future of design.' } },
			{ kind: 'react', component: WeatherTile, props: { size: '2x1', label: 'Weather', accent: 'primary', opacity: 45 } },
		]
	},
	{
		title: 'AI Lab',
		tiles: [
			{ kind: 'react', component: SpotifyAnalysisTile, props: { size: '2x1', accent: 'primary', opacity: 50 } },
			{ kind: 'react', component: ShoeDemoTile, props: { size: '2x2', accent: 'secondary', opacity: 40 } },
			{ kind: 'react', component: NextWbcTile, props: { size: '2x1', accent: 'primary', opacity: 40 } },
		]
	},
	{
		title: 'Work & Focus',
		tiles: [
			{ kind: 'astro', component: BlogTile, props: { size: '2x2', accent: 'primary', opacity: 40 } },
			{ kind: 'placeholder', id: 'tasks', size: '2x2', label: 'Tasks', icon: PenTool, accent: 'secondary', opacity: 40 },
			{ kind: 'react', component: ResourceTile, props: { size: '1x1', accent: 'primary', opacity: 25 } },
			{ kind: 'placeholder', id: 'notes', size: '1x1', label: 'Notes', icon: StickyNote, accent: 'secondary', opacity: 35 },
			{ kind: 'placeholder', id: 'project', size: '2x3', label: 'Project Alpha', accent: 'secondary', opacity: 50 },
			{ kind: 'placeholder', id: 'team', size: '2x2', label: 'Team', icon: Users, accent: 'primary', opacity: 35 },
		]
	}
] as const;

const sizeClassMap = {
	'1x1': 'tile-1x1 row-span-1 col-span-1',
	'2x1': 'tile-2x1 row-span-1 col-span-2',
	'2x2': 'tile-2x2 row-span-2 col-span-2',
	'2x3': 'tile-2x3 row-span-3 col-span-2',
	'3x2': 'tile-3x2 row-span-2 col-span-3',
} as const;
---

<Background />

<div class="home-shell-wrapper">
	<header class="home-header">
		<div class="home-header__inner">
			<h1 class="home-header__title">site(.)moss</h1>
			<div class="home-header__controls">
				<button type="button" class="home-header__btn home-header__btn--apple" data-set-ui-mode="apple">Apple</button>
				<button type="button" class="home-header__btn home-header__btn--classic" data-set-ui-mode="legacy">Classic</button>
				<button type="button" class="home-header__btn home-header__btn--settings" data-open-settings>Settings</button>
			</div>
		</div>
	</header>

	<main class="home-content">
		<section class="home-apple-panel" data-ui-shell="apple">
			<div class="home-apple-panel__overlay"></div>
			<div class="home-apple-panel__card">
				<div class="home-apple-panel__header">
					<p>Editorial & More</p>
					<h2>Explore site(.)moss</h2>
				</div>

				<nav class="home-apple-panel__nav">
					<a href="/blog" class="home-apple-panel__nav-item">
						<span class="home-apple-panel__nav-icon">📰</span>
						<div>
							<h3>Blog</h3>
							<p>Read articles with Apple-style layout</p>
						</div>
					</a>

					<a href="/" class="home-apple-panel__nav-item">
						<span class="home-apple-panel__nav-icon">⚙️</span>
						<div>
							<h3>Settings</h3>
							<p>Manage your preferences and appearance</p>
						</div>
					</a>

					<a href="/" class="home-apple-panel__nav-item">
						<span class="home-apple-panel__nav-icon">✨</span>
						<div>
							<h3>Features</h3>
							<p>Discover what makes this site unique</p>
						</div>
					</a>
				</nav>

				<div class="home-apple-panel__footer">
					<p class="home-apple-panel__footer-text">Apple UI mode is optimized for reading and navigation</p>
				</div>
			</div>
		</section>

		<section class="home-classic-panel" data-ui-shell="legacy">
			<ProfileButton />
			<div class="home-shell__veil"></div>

			<div class="home-shell__content">
				<div class="home-shell__inner">
					<header class="dashboard-header">
						<h1>Dashboard</h1>
					</header>

					<main class="dashboard-main w-fit max-w-full gap-x-8 gap-y-10 no-scrollbar pb-8">
						{dashboardGroups.map((group) => (
							<section class="dashboard-group">
								<h2>{group.title}</h2>
								<div class="dashboard-grid">
									{group.tiles.map((tile) => {
										if (tile.kind === 'react') {
											if (tile.component === ClockTile) {
												return <ClockTile client:only="react" {...tile.props} />;
											}
											if (tile.component === CalendarTile) {
												return <CalendarTile client:only="react" {...tile.props} />;
											}
											if (tile.component === WeatherTile) {
												return <WeatherTile client:only="react" {...tile.props} />;
											}
											if (tile.component === SpotifyAnalysisTile) {
												return <SpotifyAnalysisTile client:only="react" {...tile.props} />;
											}
											if (tile.component === ShoeDemoTile) {
												return <ShoeDemoTile client:only="react" {...tile.props} />;
											}
											if (tile.component === NextWbcTile) {
												return <NextWbcTile client:only="react" {...tile.props} />;
											}
											if (tile.component === ResourceTile) {
												return <ResourceTile client:only="react" {...tile.props} />;
											}
										}

										if (tile.kind === 'astro') {
											const Component = tile.component;
											return <Component {...tile.props} />;
										}

										if (tile.kind === 'quote') {
											return (
												<div class:list={["tile", sizeClassMap[tile.size], 'home-quote']} style={`background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url(${randomQuote.image}); background-size: cover; background-position: center; color: white;`}>
													<div class="home-quote__inner">
														<p>&quot;{randomQuote.text}&quot;</p>
														<span>- {randomQuote.author}</span>
													</div>
												</div>
											);
										}

										if (tile.kind === 'button') {
											const Icon = tile.icon;
											return (
												<button type="button" class:list={["tile", sizeClassMap[tile.size], 'home-tile-button']} data-open-settings>
													{Icon && <Icon size={24} strokeWidth={1.5} />}
													<span class="home-tile-label">{tile.label}</span>
												</button>
											);
										}

										const Icon = tile.icon;
										return (
											<div class:list={["tile", sizeClassMap[tile.size], 'home-tile-placeholder']}>
												{Icon && <Icon size={24} strokeWidth={1.5} />}
												<span class="home-tile-label">{tile.label}</span>
												{tile.id === 'project' && (
													<div class="home-project">
														<div class="home-project__ring"><span>75%</span></div>
														<p>In Progress</p>
													</div>
												)}
											</div>
										);
									})}
								</div>
							</section>
						))}
					</main>
				</div>
			</div>
		</section>

<div class="home-shell home-shell--legacy" data-ui-shell="legacy">
	<ProfileButton />
	<div class="home-shell__veil"></div>

	<div class="home-shell__content">
		<div class="home-shell__inner">
			<header class="dashboard-header">
				<h1>site(.)moss</h1>
			</header>

			<main class="dashboard-main w-fit max-w-full gap-x-8 gap-y-10 no-scrollbar pb-8">
				{dashboardGroups.map((group) => (
					<section class="dashboard-group">
						<h2>{group.title}</h2>
						<div class="dashboard-grid">
							{group.tiles.map((tile) => {
												if (tile.kind === 'react') {
									if (tile.component === ClockTile) {
										return <ClockTile client:only="react" {...tile.props} />;
									}
									if (tile.component === CalendarTile) {
										return <CalendarTile client:only="react" {...tile.props} />;
									}
									if (tile.component === WeatherTile) {
										return <WeatherTile client:only="react" {...tile.props} />;
									}
									if (tile.component === SpotifyAnalysisTile) {
										return <SpotifyAnalysisTile client:only="react" {...tile.props} />;
									}
									if (tile.component === ShoeDemoTile) {
										return <ShoeDemoTile client:only="react" {...tile.props} />;
									}
									if (tile.component === NextWbcTile) {
										return <NextWbcTile client:only="react" {...tile.props} />;
									}
									if (tile.component === ResourceTile) {
										return <ResourceTile client:only="react" {...tile.props} />;
									}
								}

												if (tile.kind === 'astro') {
													const Component = tile.component;
													return <Component {...tile.props} />;
												}

								if (tile.kind === 'quote') {
									return (
										<div class:list={["tile", sizeClassMap[tile.size], 'home-quote']} style={`background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url(${randomQuote.image}); background-size: cover; background-position: center; color: white;`}>
											<div class="home-quote__inner">
												<p>&quot;{randomQuote.text}&quot;</p>
												<span>- {randomQuote.author}</span>
											</div>
										</div>
									);
								}

								if (tile.kind === 'button') {
									const Icon = tile.icon;
									return (
										<button type="button" class:list={["tile", sizeClassMap[tile.size], 'home-tile-button']} data-open-settings>
											{Icon && <Icon size={24} strokeWidth={1.5} />}
											<span class="home-tile-label">{tile.label}</span>
										</button>
									);
								}

								const Icon = tile.icon;
								return (
									<div class:list={["tile", sizeClassMap[tile.size], 'home-tile-placeholder']}>
										{Icon && <Icon size={24} strokeWidth={1.5} />}
										<span class="home-tile-label">{tile.label}</span>
										{tile.id === 'project' && (
											<div class="home-project">
												<div class="home-project__ring"><span>75%</span></div>
												<p>In Progress</p>
											</div>
										)}
									</div>
								);
							})}
						</div>
		</section>
	</main>
</div>
</section>
	</div>
</div>

<SettingsModal />

<script>
	const SITE_UI_MODE_KEY = 'site-ui-mode';
	const SITE_UI_MODE_EVENT = 'site-ui-mode-change';

	const updateHeaderModeButtons = () => {
		const appleBtn = document.querySelector('[data-set-ui-mode="apple"]');
		const classicBtn = document.querySelector('[data-set-ui-mode="legacy"]');
		const currentMode = document.documentElement.getAttribute('data-ui-mode') ?? 'apple';

		appleBtn?.classList.toggle('is-active', currentMode === 'apple');
		classicBtn?.classList.toggle('is-active', currentMode === 'legacy');
	};

	// Set initial state
	const initialMode = localStorage.getItem(SITE_UI_MODE_KEY) ?? 'apple';
	document.documentElement.setAttribute('data-ui-mode', initialMode);
	updateHeaderModeButtons();

	// Listen for mode changes from other sources (settings modal)
	window.addEventListener(SITE_UI_MODE_EVENT, () => {
		updateHeaderModeButtons();
	});

	// Handle header button clicks
	document.querySelectorAll('[data-set-ui-mode]').forEach((btn) => {
		btn.addEventListener('click', () => {
			const mode = btn.getAttribute('data-set-ui-mode');
			if (!mode) return;
			localStorage.setItem(SITE_UI_MODE_KEY, mode);
			document.documentElement.setAttribute('data-ui-mode', mode);
			window.dispatchEvent(new CustomEvent(SITE_UI_MODE_EVENT, { detail: { mode } }));
			updateHeaderModeButtons();
		});
	});
</script>

<style>
	[data-ui-shell='apple'] {
		display: flex;
	}

	[data-ui-shell='legacy'] {
		display: flex;
	}

	html[data-ui-mode='legacy'] [data-ui-shell='apple'] {
		display: none;
	}

	html[data-ui-mode='legacy'] [data-ui-shell='legacy'] {
		display: flex;
	}

	html[data-ui-mode='apple'] [data-ui-shell='apple'] {
		display: flex;
	}

	html[data-ui-mode='apple'] [data-ui-shell='legacy'] {
		display: none;
	}

	.home-shell-wrapper {
		position: relative;
		width: 100%;
		height: 100vh;
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}

	.home-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: color-mix(in srgb, var(--background) 88%, transparent);
		border-bottom: 1px solid color-mix(in srgb, var(--foreground) 12%, transparent);
		backdrop-filter: blur(18px);
		padding: 1rem 0;
	}

	.home-header__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.home-header__title {
		margin: 0;
		font-size: clamp(1.2rem, 3vw, 1.8rem);
		font-weight: 600;
		letter-spacing: -0.025em;
		color: var(--foreground);
	}

	.home-header__controls {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.home-header__btn {
		padding: 0.6rem 1.2rem;
		border: 1px solid color-mix(in srgb, var(--foreground) 18%, transparent);
		border-radius: 0.7rem;
		background: color-mix(in srgb, var(--foreground) 5%, transparent);
		color: var(--foreground);
		font-size: 0.85rem;
		font-weight: 600;
		cursor: pointer;
		transition: all 200ms ease;
	}

	.home-header__btn:hover {
		background: color-mix(in srgb, var(--foreground) 12%, transparent);
		border-color: color-mix(in srgb, var(--foreground) 28%, transparent);
	}

	.home-header__btn--apple.is-active,
	.home-header__btn--classic.is-active {
		background: var(--accent-primary);
		color: var(--background);
		border-color: var(--accent-primary);
	}

	.home-content {
		flex: 1;
		position: relative;
		overflow: hidden;
		display: flex;
		flex-direction: column;
	}

	.home-apple-panel {
		position: relative;
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		overflow-y: auto;
	}

	.home-apple-panel__overlay {
		position: absolute;
		inset: 0;
		background: radial-gradient(1200px 500px at 50% -80px, color-mix(in srgb, var(--accent-primary) 18%, transparent), transparent 60%);
		pointer-events: none;
	}

	.home-apple-panel__card {
		position: relative;
		z-index: 10;
		width: 100%;
		max-width: 480px;
		background: color-mix(in srgb, var(--background) 92%, transparent);
		border: 1px solid color-mix(in srgb, var(--foreground) 16%, transparent);
		border-radius: 2rem;
		padding: 2.5rem;
		backdrop-filter: blur(20px);
		box-shadow: 0 30px 60px -40px rgba(0, 0, 0, 0.5);
	}

	.home-apple-panel__header p {
		margin: 0;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		opacity: 0.55;
	}

	.home-apple-panel__header h2 {
		margin: 0.8rem 0 0;
		font-size: 2rem;
		font-weight: 650;
		letter-spacing: -0.03em;
		line-height: 1.1;
	}

	.home-apple-panel__nav {
		margin-top: 2rem;
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.home-apple-panel__nav-item {
		display: flex;
		align-items: flex-start;
		gap: 1.2rem;
		padding: 1.2rem;
		border-bottom: 1px solid color-mix(in srgb, var(--foreground) 8%, transparent);
		text-decoration: none;
		color: inherit;
		transition: background-color 200ms ease;
	}

	.home-apple-panel__nav-item:last-child {
		border-bottom: none;
	}

	.home-apple-panel__nav-item:hover {
		background: color-mix(in srgb, var(--foreground) 5%, transparent);
	}

	.home-apple-panel__nav-icon {
		font-size: 1.8rem;
		flex-shrink: 0;
		line-height: 1;
	}

	.home-apple-panel__nav-item h3 {
		margin: 0 0 0.3rem;
		font-size: 0.95rem;
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	.home-apple-panel__nav-item p {
		margin: 0;
		font-size: 0.82rem;
		color: color-mix(in srgb, var(--foreground) 60%, transparent);
		line-height: 1.4;
	}

	.home-apple-panel__footer {
		margin-top: 1.8rem;
		padding-top: 1.2rem;
		border-top: 1px solid color-mix(in srgb, var(--foreground) 12%, transparent);
	}

	.home-apple-panel__footer-text {
		margin: 0;
		font-size: 0.8rem;
		color: color-mix(in srgb, var(--foreground) 50%, transparent);
		text-align: center;
	}

	.home-classic-panel {
		position: relative;
		width: 100%;
		height: 100%;
		display: flex;
		flex-direction: column;
	}

	.home-shell {
		position: relative;
		width: 100%;
		height: 100%;
		overflow-x: hidden;
		font-family: var(--font-sans);
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.home-shell__veil {
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		background: color-mix(in srgb, var(--background) 5%, transparent);
		backdrop-filter: blur(1px);
	}

	.home-shell__content {
		position: relative;
		z-index: 2;
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 3rem 0;
		overflow-y: auto;
	}

	.home-shell__inner {
		width: fit-content;
		max-width: 100%;
		padding: 0 1.5rem;
	}
	.dashboard-header {
		margin-bottom: 2rem;
	}

	.dashboard-header h1 {
		margin: 0;
		font-size: clamp(3rem, 6vw, 4rem);
		font-weight: 300;
		letter-spacing: -0.04em;
	}

	.dashboard-main {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}
	.dashboard-header {
		margin-bottom: 2rem;
	}

	.dashboard-header h1 {
		margin: 0;
		font-size: clamp(3rem, 6vw, 4rem);
		font-weight: 300;
		letter-spacing: -0.04em;
	}

	.dashboard-group {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		align-items: flex-start;
		margin-bottom: 1rem;
	}

	.dashboard-group h2 {
		margin: 0 0 0 0.25rem;
		font-size: 0.625rem;
		font-weight: 700;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		opacity: 0.6;
	}

	.dashboard-grid {
		display: grid;
		grid-template-rows: repeat(5, minmax(0, 1fr));
		grid-auto-flow: column;
		gap: 0.375rem;
		height: 21.5rem;
		width: max-content;
	}

	.home-tile-button,
	.home-tile-placeholder {
		flex-direction: column;
		gap: 0.5rem;
	}

	.home-quote {
		justify-content: center;
		align-items: center;
		color: white;
		padding: 0.5rem 0.75rem;
	}

	.home-tile-label {
		font-size: 0.45rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-weight: 700;
	}

	.home-quote__inner {
		text-align: center;
		padding: 0 0.75rem;
		position: relative;
		z-index: 1;
	}

	.home-quote__inner p {
		margin: 0 0 0.5rem;
		font-size: 0.75rem;
		font-style: italic;
		line-height: 1.2;
	}

	.home-quote__inner span {
		font-size: 0.56rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-weight: 700;
	}

	.home-project {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.25rem;
		margin-top: 0.25rem;
	}

	.home-project__ring {
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 999px;
		border: 2px solid color-mix(in srgb, var(--tile-text) 30%, transparent);
		display: grid;
		place-items: center;
	}

	.home-project__ring span {
		font-size: 0.65rem;
