---
import Background from './Background.astro';
import ProfileButton from './ProfileButton.astro';
import SettingsModal from './SettingsModal.astro';

import WeatherTile from '@/components/WeatherTile';
import AdTile from './AdTile.astro';
import CalendarTile from '@/components/CalendarTile';
import ClockTile from '@/components/ClockTile';
import ShoeDemoTile from '@/components/ShoeDemoTile';
import NextWbcTile from '@/components/NextWbcTile';
import SpotifyAnalysisTile from '@/components/SpotifyAnalysisTile';
import BlogTile from './BlogTile.astro';
import ResourceTile from '@/components/ResourceTile';
import { Settings, Users, PenTool, StickyNote } from 'lucide-react';

const QUOTES = [
	{ text: 'The only way to do great work is to love what you do.', author: 'Steve Jobs', image: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=400&q=60' },
	{ text: 'Stay hungry, stay foolish.', author: 'Steve Jobs', image: 'https://images.unsplash.com/photo-1550745165-9bc0b252726f?auto=format&fit=crop&w=400&q=60' },
	{ text: 'The future belongs to those who believe in the beauty of their dreams.', author: 'Eleanor Roosevelt', image: 'https://images.unsplash.com/photo-1485872232694-217b2ad2303e?auto=format&fit=crop&w=400&q=60' },
] as const;

const randomQuote = QUOTES[Math.floor(Math.random() * QUOTES.length)];

const dashboardGroups = [
	{
		title: 'Life at a glance',
		tiles: [
			{ kind: 'react', component: ClockTile, props: { size: '2x2', label: 'Clock', accent: 'primary', opacity: 55 } },
			{ kind: 'react', component: CalendarTile, props: { size: '2x3', label: 'Calendar', accent: 'secondary', opacity: 65 } },
			{ kind: 'button', id: 'settings', size: '1x1', label: 'Settings', icon: Settings, accent: 'secondary', opacity: 60 },
			{ kind: 'quote', size: '3x2' },
			{ kind: 'astro', component: AdTile, props: { size: '3x2', title: 'New Collection 2025', description: 'Discover the future of design.' } },
			{ kind: 'react', component: WeatherTile, props: { size: '2x1', label: 'Weather', accent: 'primary', opacity: 45 } },
		]
	},
	{
		title: 'AI Lab',
		tiles: [
			{ kind: 'react', component: SpotifyAnalysisTile, props: { size: '2x1', accent: 'primary', opacity: 50 } },
			{ kind: 'react', component: ShoeDemoTile, props: { size: '2x2', accent: 'secondary', opacity: 40 } },
			{ kind: 'react', component: NextWbcTile, props: { size: '2x1', accent: 'primary', opacity: 40 } },
		]
	},
	{
		title: 'Work & Focus',
		tiles: [
			{ kind: 'astro', component: BlogTile, props: { size: '2x2', accent: 'primary', opacity: 40 } },
			{ kind: 'placeholder', id: 'tasks', size: '2x2', label: 'Tasks', icon: PenTool, accent: 'secondary', opacity: 40 },
			{ kind: 'react', component: ResourceTile, props: { size: '1x1', accent: 'primary', opacity: 25 } },
			{ kind: 'placeholder', id: 'notes', size: '1x1', label: 'Notes', icon: StickyNote, accent: 'secondary', opacity: 35 },
			{ kind: 'placeholder', id: 'project', size: '2x3', label: 'Project Alpha', accent: 'secondary', opacity: 50 },
			{ kind: 'placeholder', id: 'team', size: '2x2', label: 'Team', icon: Users, accent: 'primary', opacity: 35 },
		]
	}
] as const;

const sizeClassMap = {
	'1x1': 'tile-1x1 row-span-1 col-span-1',
	'2x1': 'tile-2x1 row-span-1 col-span-2',
	'2x2': 'tile-2x2 row-span-2 col-span-2',
	'2x3': 'tile-2x3 row-span-3 col-span-2',
	'3x2': 'tile-3x2 row-span-2 col-span-3',
} as const;
---

<Background />

<section class="home-apple" data-ui-shell="apple">
	<ProfileButton />
	<div class="home-apple__glow home-apple__glow--one"></div>
	<div class="home-apple__glow home-apple__glow--two"></div>

	<div class="home-apple__inner">
		<header class="home-apple__hero">
			<p>site(.)moss</p>
			<h1>Build stories that sell before the first scroll.</h1>
			<p class="home-apple__lead">Apple UI mode is now the default across pages so visitors land on dedicated routes, better for SEO, ad delivery, and retention.</p>
		</header>

		<div class="home-apple__grid">
			<a href="/blog" class="home-apple__card home-apple__card--feature">
				<span>Editorial Hub</span>
				<h2>Open the Blog experience</h2>
				<p>Featured layouts, endpoint navigation, and ad-friendly reading flow.</p>
			</a>

			<a href="/blog" class="home-apple__card home-apple__card--media" style={`background-image: linear-gradient(120deg, rgba(6, 7, 10, 0.25), rgba(6, 7, 10, 0.62)), url(${randomQuote.image});`}>
				<span>Spotlight</span>
				<h2>&quot;{randomQuote.text}&quot;</h2>
				<p>{randomQuote.author}</p>
			</a>

			<button type="button" class="home-apple__card home-apple__card--settings" data-open-settings>
				<span>Preferences</span>
				<h2>Switch UI version</h2>
				<p>Settings stays modal in both versions as requested.</p>
			</button>
		</div>
	</div>
</section>

<div class="home-shell home-shell--legacy" data-ui-shell="legacy">
	<ProfileButton />
	<div class="home-shell__veil"></div>

	<div class="home-shell__content">
		<div class="home-shell__inner">
			<header class="dashboard-header">
				<h1>site(.)moss</h1>
			</header>

			<main class="dashboard-main w-fit max-w-full gap-x-8 gap-y-10 no-scrollbar pb-8">
				{dashboardGroups.map((group) => (
					<section class="dashboard-group">
						<h2>{group.title}</h2>
						<div class="dashboard-grid">
							{group.tiles.map((tile) => {
												if (tile.kind === 'react') {
									if (tile.component === ClockTile) {
										return <ClockTile client:only="react" {...tile.props} />;
									}
									if (tile.component === CalendarTile) {
										return <CalendarTile client:only="react" {...tile.props} />;
									}
									if (tile.component === WeatherTile) {
										return <WeatherTile client:only="react" {...tile.props} />;
									}
									if (tile.component === SpotifyAnalysisTile) {
										return <SpotifyAnalysisTile client:only="react" {...tile.props} />;
									}
									if (tile.component === ShoeDemoTile) {
										return <ShoeDemoTile client:only="react" {...tile.props} />;
									}
									if (tile.component === NextWbcTile) {
										return <NextWbcTile client:only="react" {...tile.props} />;
									}
									if (tile.component === ResourceTile) {
										return <ResourceTile client:only="react" {...tile.props} />;
									}
								}

												if (tile.kind === 'astro') {
													const Component = tile.component;
													return <Component {...tile.props} />;
												}

								if (tile.kind === 'quote') {
									return (
										<div class:list={["tile", sizeClassMap[tile.size], 'home-quote']} style={`background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url(${randomQuote.image}); background-size: cover; background-position: center; color: white;`}>
											<div class="home-quote__inner">
												<p>&quot;{randomQuote.text}&quot;</p>
												<span>- {randomQuote.author}</span>
											</div>
										</div>
									);
								}

								if (tile.kind === 'button') {
									const Icon = tile.icon;
									return (
										<button type="button" class:list={["tile", sizeClassMap[tile.size], 'home-tile-button']} data-open-settings>
											{Icon && <Icon size={24} strokeWidth={1.5} />}
											<span class="home-tile-label">{tile.label}</span>
										</button>
									);
								}

								const Icon = tile.icon;
								return (
									<div class:list={["tile", sizeClassMap[tile.size], 'home-tile-placeholder']}>
										{Icon && <Icon size={24} strokeWidth={1.5} />}
										<span class="home-tile-label">{tile.label}</span>
										{tile.id === 'project' && (
											<div class="home-project">
												<div class="home-project__ring"><span>75%</span></div>
												<p>In Progress</p>
											</div>
										)}
									</div>
								);
							})}
						</div>
					</section>
				))}
			</main>
		</div>
	</div>
</div>

<SettingsModal />

<style>
	[data-ui-shell='apple'] {
		display: block;
	}

	[data-ui-shell='legacy'] {
		display: none;
	}

	html[data-ui-mode='legacy'] [data-ui-shell='apple'] {
		display: none;
	}

	html[data-ui-mode='legacy'] [data-ui-shell='legacy'] {
		display: block;
	}

	.home-apple {
		position: relative;
		min-height: 100vh;
		overflow: hidden;
		padding: clamp(5rem, 9vw, 7rem) 1.25rem 3rem;
	}

	.home-apple__inner {
		position: relative;
		z-index: 2;
		max-width: 1080px;
		margin: 0 auto;
	}

	.home-apple__hero p {
		margin: 0;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		opacity: 0.55;
	}

	.home-apple__hero h1 {
		margin: 1rem 0 0;
		max-width: 18ch;
		font-size: clamp(2.25rem, 6vw, 4.5rem);
		line-height: 0.95;
		letter-spacing: -0.045em;
		font-weight: 600;
	}

	.home-apple__lead {
		margin-top: 1.25rem;
		max-width: 62ch;
		font-size: clamp(0.95rem, 2vw, 1.1rem);
		line-height: 1.7;
		opacity: 0.72;
	}

	.home-apple__grid {
		margin-top: clamp(1.75rem, 4vw, 3rem);
		display: grid;
		grid-template-columns: repeat(12, minmax(0, 1fr));
		gap: 0.75rem;
	}

	.home-apple__card {
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		text-decoration: none;
		text-align: left;
		border: 1px solid color-mix(in srgb, var(--foreground) 14%, transparent);
		border-radius: 2rem;
		background: color-mix(in srgb, var(--background) 88%, transparent);
		min-height: 14rem;
		padding: 1.6rem;
		backdrop-filter: blur(14px);
		box-shadow: 0 28px 50px -46px rgba(0, 0, 0, 0.66);
		transition: transform 280ms ease, border-color 220ms ease;
		cursor: pointer;
		color: inherit;
	}

	.home-apple__card:hover {
		transform: translateY(-4px);
		border-color: color-mix(in srgb, var(--foreground) 28%, transparent);
	}

	.home-apple__card span {
		font-size: 0.62rem;
		text-transform: uppercase;
		letter-spacing: 0.24em;
		font-weight: 700;
		opacity: 0.55;
	}

	.home-apple__card h2 {
		margin: 0.8rem 0 0;
		font-size: clamp(1.35rem, 2.5vw, 2.2rem);
		line-height: 1.05;
		letter-spacing: -0.03em;
	}

	.home-apple__card p {
		margin: 0.9rem 0 0;
		font-size: 0.92rem;
		line-height: 1.6;
		opacity: 0.72;
	}

	.home-apple__card--feature {
		grid-column: span 7;
	}

	.home-apple__card--media {
		grid-column: span 5;
		background-size: cover;
		background-position: center;
		color: #fff;
	}

	.home-apple__card--settings {
		grid-column: span 12;
	}

	.home-apple__glow {
		position: absolute;
		border-radius: 999px;
		pointer-events: none;
		filter: blur(80px);
		opacity: 0.35;
	}

	.home-apple__glow--one {
		height: 18rem;
		width: 18rem;
		right: -3rem;
		top: 3rem;
		background: color-mix(in srgb, var(--accent-primary) 55%, transparent);
	}

	.home-apple__glow--two {
		height: 16rem;
		width: 16rem;
		left: -5rem;
		bottom: 2rem;
		background: color-mix(in srgb, var(--accent-secondary) 58%, transparent);
	}

	.home-shell {
		position: relative;
		min-height: 100vh;
		width: 100%;
		overflow-x: hidden;
		font-family: var(--font-sans);
	}

	.home-shell__veil {
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		background: color-mix(in srgb, var(--background) 5%, transparent);
		backdrop-filter: blur(1px);
	}

	.home-shell__content {
		position: relative;
		z-index: 2;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 3rem 0;
	}

	.home-shell__inner {
		width: fit-content;
		max-width: 100%;
		padding: 0 1.5rem;
	}

	.dashboard-header {
		margin-bottom: 2rem;
	}

	.dashboard-header h1 {
		margin: 0;
		font-size: clamp(3rem, 6vw, 4rem);
		font-weight: 300;
		letter-spacing: -0.04em;
	}

	.dashboard-group {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		align-items: flex-start;
		margin-bottom: 1rem;
	}

	.dashboard-group h2 {
		margin: 0 0 0 0.25rem;
		font-size: 0.625rem;
		font-weight: 700;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		opacity: 0.6;
	}

	.dashboard-grid {
		display: grid;
		grid-template-rows: repeat(5, minmax(0, 1fr));
		grid-auto-flow: column;
		gap: 0.375rem;
		height: 21.5rem;
		width: max-content;
	}

	.home-tile-button,
	.home-tile-placeholder {
		flex-direction: column;
		gap: 0.5rem;
	}

	.home-quote {
		justify-content: center;
		align-items: center;
		color: white;
		padding: 0.5rem 0.75rem;
	}

	.home-tile-label {
		font-size: 0.45rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-weight: 700;
	}

	.home-quote__inner {
		text-align: center;
		padding: 0 0.75rem;
		position: relative;
		z-index: 1;
	}

	.home-quote__inner p {
		margin: 0 0 0.5rem;
		font-size: 0.75rem;
		font-style: italic;
		line-height: 1.2;
	}

	.home-quote__inner span {
		font-size: 0.56rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-weight: 700;
	}

	.home-project {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.25rem;
		margin-top: 0.25rem;
	}

	.home-project__ring {
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 999px;
		border: 2px solid color-mix(in srgb, var(--tile-text) 30%, transparent);
		display: grid;
		place-items: center;
	}

	.home-project__ring span {
		font-size: 0.65rem;
		font-weight: 700;
	}

	@media (max-width: 768px) {
		.home-apple {
			padding-top: 4.75rem;
		}

		.home-apple__grid {
			grid-template-columns: 1fr;
		}

		.home-apple__card--feature,
		.home-apple__card--media,
		.home-apple__card--settings {
			grid-column: span 1;
		}

		.home-shell__content {
			padding: 2rem 0 4rem;
		}

		.home-shell__inner {
			padding: 0 1rem;
		}
	}
</style>
