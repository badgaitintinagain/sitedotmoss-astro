---
import '../styles/globals.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<script is:inline>
			const root = document.documentElement;
			try {
				const theme = localStorage.getItem('theme');
				if (theme === 'dark') root.classList.add('dark');
				const glassBlur = localStorage.getItem('glassBlur');
				if (glassBlur) root.style.setProperty('--glass-blur', `${glassBlur}px`);
				const bgType = localStorage.getItem('bgType');
				const bgValue = localStorage.getItem('bgValue');
				if (bgType && bgValue) root.style.setProperty('--bg-image', bgType === 'image' ? `url(${bgValue})` : 'none');
				const customPrimary = localStorage.getItem('customPrimary');
				const customSecondary = localStorage.getItem('customSecondary');
				if (customPrimary) root.style.setProperty('--accent-primary', customPrimary);
				if (customSecondary) root.style.setProperty('--accent-secondary', customSecondary);
				if (localStorage.getItem('grayscale') === 'true') root.classList.add('force-grayscale');
			} catch {}
		</script>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
		<link rel="preconnect" href="https://images.unsplash.com" crossorigin="anonymous" />
		<link rel="dns-prefetch" href="https://images.unsplash.com" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content="Windows 8 Metro UI style dashboard with pastel aesthetic" />
		<meta name="generator" content={Astro.generator} />
		<title>site(.)moss</title>
	</head>
	<body>
		<slot />
	</body>
</html>
